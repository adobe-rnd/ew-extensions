{
  "name": "da-skills",
  "version": "1.0.0",
  "private": true,
  "description": "Skills editor DA app — manage skills, agents, prompts, MCPs, and memory",
  "license": "Apache-2.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/exp-workspace/da-skills.git"
  },
  "scripts": {
    "lint": "npm run lint:js && npm run lint:css",
    "lint:js": "eslint blocks/",
    "lint:css": "stylelint 'blocks/**/*.css'",
    "test": "wtr --config ./web-test-runner.config.mjs \"./test/unit/**/*.test.js\" --node-resolve --port=2000",
    "test:e2e": "playwright test --project=chromium",
    "test:e2e:all": "playwright test --project=chromium --project=firefox --project=webkit",
    "test:e2e:ui": "playwright test --project=chromium --ui",
    "test:e2e:report": "playwright show-report",
    "prepare": "husky"
  },
  "devDependencies": {
    "@adobe/eslint-config-helix": "^2.0.8",
    "@esm-bundle/chai": "^4.3.4-fix.0",
    "@playwright/test": "^1.57.0",
    "@web/dev-server-import-maps": "^0.2.1",
    "@web/test-runner": "^0.20.2",
    "@web/test-runner-puppeteer": "^0.18.0",
    "dotenv": "^17.4.2",
    "eslint": "^8.57.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.4",
    "stylelint": "^16.20.0",
    "stylelint-config-standard": "^38.0.0"
  },
  "lint-staged": {
    "*.js": "eslint --fix",
    "*.css": "stylelint --fix"
  }
}
